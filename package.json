{
  "name": "ai-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "deploy": "wrangler deploy",
    "deploy:stg": "wrangler deploy --env staging",
    "dev": "react-router dev",
    "start": "wrangler dev --env local-build",
    "typegen": "wrangler types",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .; stylelint --cache --cache-location ./node_modules/.cache/stylelint 'app/**/*.css'",
    "lint:claude": "claude -p 'あなたはリンターです。差分をを確認し、タイポに関連する問題を報告してください。ファイル名と行番号を1行で報告し、問題の説明を2行目で報告してください。他のテキストは返さないでください。' --output-format json",
    "typecheck": "react-router typegen && tsc",
    "auth:generate": "npx @better-auth/cli generate --config ./auth.config.ts",
    "db:generate": "drizzle-kit generate --config ./drizzle/config/drizzle-local.config.ts",
    "db:migrate-local": "drizzle-kit migrate --config ./drizzle/config/drizzle-local.config.ts ",
    "db:migrate-local-build": "drizzle-kit migrate --config ./drizzle/config/drizzle-local-build.config.ts ",
    "db:migrate-dev": "drizzle-kit migrate --config ./drizzle/config/drizzle-dev.config.ts",
    "db:migrate-stg": "drizzle-kit migrate --config ./drizzle/config/drizzle-stg.config.ts",
    "db:migrate-prod": "drizzle-kit migrate --config ./drizzle/config/drizzle-prod.config.ts",
    "db:drop-all-local": "rm -rf .wrangler/state/v3/d1",
    "db:drop-all-prod": "echo \"🔥 Be careful 🔥\nYou can delete all tables in the production environment database by executing the following command.\n> wrangler d1 execute rtrr-cf-workers-test --remote --file='./db/seed/drop-all-table.sql'\"",
    "db:view-local": "drizzle-kit studio --config ./drizzle/config/drizzle-local.config.ts",
    "db:view-local-build": "drizzle-kit studio --config ./drizzle/config/drizzle-local-build.config.ts",
    "db:view-dev": "drizzle-kit studio --config ./drizzle/config/drizzle-dev.config.ts",
    "db:view-stg": "drizzle-kit studio --config ./drizzle/config/drizzle-stg.config.ts",
    "db:view-prod": "drizzle-kit studio --config ./drizzle/config/drizzle-prod.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.83",
    "@cloudflare/workers-types": "^4.20250731.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-router/cloudflare": "^7.7.1",
    "@react-router/fs-routes": "^7.7.1",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "better-auth": "^1.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.4",
    "isbot": "^5.1.29",
    "lucide-react": "^0.539.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-router": "^7.7.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.32.0",
    "@react-router/dev": "^7.7.1",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.1",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "lefthook": "^1.12.2",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-router-devtools": "^5.0.6",
    "stylelint": "^16.23.0",
    "stylelint-config-standard": "^39.0.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.4",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.27.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.6.3+sha512.bb45e34d50a9a76e858a95837301bfb6bd6d35aea2c5d52094fa497a467c43f5c440103ce2511e9e0a2f89c3d6071baac3358fc68ac6fb75e2ceb3d2736065e6"
}
